    },
    "%lld / 15 🏆": {
      "comment": "A label displaying the number of gold cups collected to unlock the Emoji theme. The argument is the number of gold cups collected.",
      "isCommentAutoGenerated": true
    },
    "%lld / 5 🏆": {
      "comment": "A label showing the number of gold cups collected. The argument is the number of gold cups collected.",
      "isCommentAutoGenerated": true
    },
    "%lld.": {
      "comment": "A number followed by a period, used to number each math problem in a list. The argument is the index of the problem in the list (starting at 1).",
      "isCommentAutoGenerated": true
    },
    "(%lld)": {
      "comment": "A small label inside the result row that shows the correct answer for a math problem. The argument is the correct answer to the math problem.",
      "isCommentAutoGenerated": true
    },
